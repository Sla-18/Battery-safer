  <!-- HORÁRIO SILENCIOSO -->
  <div class="section-card">
    <div class="section-title">🌙 horário silencioso</div>
    <div class="toggle-row">
      <div class="toggle-info">
        <span class="toggle-name">Activar horário silencioso</span>
        <span class="toggle-desc">Adia alertas fora do período activo</span>
      </div>
      <div class="toggle on" id="quietToggle" onclick="toggleQuiet()"></div>
    </div>
    <div class="time-row" id="quietTimes">
      <div class="time-group">
        <label>início silêncio</label>
        <input type="time" id="quietStart" value="00:00">
      </div>
      <div class="divider">→</div>
      <div class="time-group">
        <label>fim silêncio</label>
        <input type="time" id="quietEnd" value="06:00">
      </div>
    </div>
  </div>

  <!-- DIAS -->
  <div class="section-card">
    <div class="section-title">📅 dias activos</div>
    <div class="days-grid" id="daysGrid">
      <button class="day-btn active" data-day="0">Dom</button>
      <button class="day-btn active" data-day="1">Seg</button>
      <button class="day-btn active" data-day="2">Ter</button>
      <button class="day-btn active" data-day="3">Qua</button>
      <button class="day-btn active" data-day="4">Qui</button>
      <button class="day-btn active" data-day="5">Sex</button>
      <button class="day-btn active" data-day="6">Sáb</button>
    </div>
  </div>

  <!-- SOM -->
  <div class="section-card">
    <div class="section-title">🔊 som e volume</div>
    <div class="sound-grid" id="soundGrid">
      <button class="sound-btn active" data-sound="beep"><span class="icon">📢</span> Bip simples</button>
      <button class="sound-btn" data-sound="alarm"><span class="icon">🔔</span> Alarme</button>
      <button class="sound-btn" data-sound="urgent"><span class="icon">🚨</span> Urgente</button>
      <button class="sound-btn" data-sound="gentle"><span class="icon">🎵</span> Suave</button>
      <label class="custom-file-btn" id="customFileLabel">
        <span>📁</span> <span id="customFileName">Ficheiro personalizado</span>
        <input type="file" id="customFile" accept="audio/*" onchange="loadCustomSound(this)">
      </label>
    </div>
    <div class="slider-row">
      <span class="slider-label">Volume</span>
      <input type="range" id="volumeSlider" min="0" max="100" value="80">
      <span class="slider-value" id="volumeVal">80%</span>
    </div>
    <div class="slider-row" style="margin-top:12px">
      <span class="slider-label">Repetições</span>
      <input type="range" id="repeatSlider" min="1" max="5" value="3">
      <span class="slider-value" id="repeatVal">3×</span>
    </div>
    <button class="test-btn" onclick="testSound()">▶ Testar Som</button>
  </div>
</div>

<button class="main-toggle-btn off" id="mainBtn" onclick="toggleMonitor()">
  ▶ INICIAR MONITORIZAÇÃO
</button>

<!-- Capacitor runtime (injectado automaticamente pelo build, mas importado aqui para dev) -->
<script>
// ========================
// CAPACITOR BATTERY BRIDGE
// ========================
// Tenta usar o plugin nativo Capacitor; cai para Battery Web API se falhar.

const BatteryBridge = (() => {
  let _listener = null;   // callback(pct, charging)
  let _interval = null;
  let _mode = 'none';     // 'capacitor' | 'web' | 'none'

  // --- Capacitor nativo ---
  async function tryCapacitor(cb) {
    try {
      // O Capacitor injeta window.Capacitor e os plugins via JSBridge
      if (typeof window.Capacitor === 'undefined') return false;
      const { Device } = window.Capacitor.Plugins;
      if (!Device) return false;

      // @capacitor-community/battery-info expõe getBatteryInfo()
      const { BatteryInfo } = window.Capacitor.Plugins;
      if (!BatteryInfo) return false;

      const info = await BatteryInfo.getBatteryInfo();
      cb(Math.round(info.batteryLevel * 100), info.isCharging);

      // Polling a cada 30s (plugin não tem evento nativo estável)
      _interval = setInterval(async () => {
        const i = await BatteryInfo.getBatteryInfo();
        cb(Math.round(i.batteryLevel * 100), i.isCharging);
      }, 30000);

      _mode = 'capacitor';
      return true;
    } catch (e) {
      return false;
    }
  }

  // --- Web Battery API (fallback browser/debug) ---
  async function tryWebBattery(cb) {
    try {
      if (!('getBattery' in navigator)) return false;
      const battery = await navigator.getBattery();

      const update = () => cb(Math.round(battery.level * 100), battery.charging);
      battery.addEventListener('levelchange', update);
      battery.addEventListener('chargingchange', update);
      update();

      _mode = 'web';
      return true;
    } catch (e) {
      return false;
    }
  }

  return {
    async init(cb) {
      _listener = cb;
      const ok = await tryCapacitor(cb) || await tryWebBattery(cb);
      return { ok, mode: _mode };
    },
    getMode() { return _mode; },
    destroy() { if (_interval) clearInterval(_interval); }
  };
})();

// ========================
// STATE
// ========================
const state = {
  active: false,
  currentPct: null,
  threshold: 20,
  quietEnabled: true,
  quietStart: '00:00',
  quietEnd: '06:00',
  activeDays: [0,1,2,3,4,5,6],
  selectedSound: 'beep',
  volume: 0.8,
  repeats: 3,
  customAudioUrl: null,
  alertFired: false,
  pendingAlertTime: null,
  checkInterval: null,
  audioCtx: null,
};

// ========================
// AUDIO
// ========================
function getAudioCtx() {
  if (!state.audioCtx || state.audioCtx.state === 'closed') {
    state.audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
  if (state.audioCtx.state === 'suspended') state.audioCtx.resume();
  return state.audioCtx;
}

function playTone(freq, duration, type = 'sine', gain = 0.8) {
  const ctx = getAudioCtx();
  const osc = ctx.createOscillator();
  const gainNode = ctx.createGain();
  osc.connect(gainNode);
  gainNode.connect(ctx.destination);
  osc.type = type;
  osc.frequency.value = freq;
  gainNode.gain.setValueAtTime(gain * state.volume, ctx.currentTime);
  gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration);
  osc.start(ctx.currentTime);
  osc.stop(ctx.currentTime + duration);
}

const sounds = {
  beep: () => {
    playTone(880, 0.15, 'square', 0.6);
    setTimeout(() => playTone(880, 0.15, 'square', 0.6), 200);
    setTimeout(() => playTone(1320, 0.3, 'square', 0.7), 400);
  },
  alarm: () => {
    for (let i = 0; i < 6; i++)
      setTimeout(() => playTone(i % 2 === 0 ? 880 : 660, 0.2, 'sawtooth', 0.5), i * 250);
  },
  urgent: () => {
    for (let i = 0; i < 8; i++)
      setTimeout(() => playTone(i % 2 === 0 ? 1200 : 800, 0.1, 'square', 0.7), i * 130);
  },
  gentle: () => {
    playTone(523, 0.3, 'sine', 0.5);
    setTimeout(() => playTone(659, 0.3, 'sine', 0.5), 350);
    setTimeout(() => playTone(784, 0.5, 'sine', 0.5), 700);
  },
};

function playSound() {
  if (state.customAudioUrl) {
    const audio = new Audio(state.customAudioUrl);
    audio.volume = state.volume;
    audio.play().catch(() => {});
    return;
  }
  const fn = sounds[state.selectedSound] || sounds.beep;
  let count = 0;
  const play = () => { fn(); count++; if (count < state.repeats) setTimeout(play, 1800); };
  play();
}

// ========================
// UI
// ========================
function updateBatteryUI(pct, charging) {
  document.getElementById('battPct').textContent = pct != null ? pct + '%' : '--%';
  document.getElementById('battStatusText').textContent =
    pct != null ? (charging ? 'A carregar' : 'A descarregar') : 'Sem dados';
  document.getElementById('chargingTag').classList.toggle('visible', !!charging);

  const bar = document.getElementById('battBar');
  bar.style.width = (pct || 0) + '%';

  if (pct <= 20) bar.style.background = 'linear-gradient(90deg, #ff3b30, #ff5f57)';
  else if (pct <= 40) bar.style.background = 'linear-gradient(90deg, #ff9500, #ffd60a)';
  else bar.style.background = 'linear-gradient(90deg, #ff5f57, #ffd60a, #00e5a0)';

  const pos = Math.min(Math.max(state.threshold, 1), 99);
  const marker = document.getElementById('thresholdMarker');
  marker.style.left = pos + '%';
  marker.setAttribute('data-label', pos + '%');
}

function updateSourceBadge(mode) {
  const badge = document.getElementById('sourceBadge');
  if (mode === 'capacitor') {
    badge.className = 'source-badge native';
    badge.textContent = '✓ nativo';
  } else if (mode === 'web') {
    badge.className = 'source-badge web';
    badge.textContent = '⚠ web api';
  } else {
    badge.className = '';
    badge.textContent = '';
  }
}

function showAlertBanner(type, title, desc) {
  const el = document.getElementById('alertBanner');
  el.className = 'alert-banner show' + (type === 'deferred' ? ' deferred' : '');
  document.getElementById('alertBannerTitle').textContent = title;
  document.getElementById('alertBannerDesc').textContent = desc;
  el.classList.add('alert-flash');
  setTimeout(() => el.classList.remove('alert-flash'), 2000);
}

function hideAlertBanner() {
  document.getElementById('alertBanner').className = 'alert-banner';
}

function showPendingTag(timeStr) {
  document.getElementById('pendingAlert').innerHTML =
    `<div class="pending-tag">⏰ Alerta pendente — dispara às ${timeStr}</div>`;
}

function clearPendingTag() {
  document.getElementById('pendingAlert').innerHTML = '';
}

// ========================
// QUIET HOURS / DIAS
// ========================
function isInQuietHours() {
  if (!state.quietEnabled) return false;
  const now = new Date();
  const cur = now.getHours() * 60 + now.getMinutes();
  const [sh, sm] = state.quietStart.split(':').map(Number);
  const [eh, em] = state.quietEnd.split(':').map(Number);
  const start = sh * 60 + sm, end = eh * 60 + em;
  return start <= end ? (cur >= start && cur < end) : (cur >= start || cur < end);
}

function isDayActive() {
  return state.activeDays.includes(new Date().getDay());
}

function getQuietEndTime() {
  const [eh, em] = state.quietEnd.split(':').map(Number);
  return `${String(eh).padStart(2,'0')}:${String(em).padStart(2,'0')}`;
}

// ========================
// CHECK BATTERY
// ========================
function checkBattery() {
  if (!state.active || state.currentPct == null) return;
  const pct = state.currentPct;

  if (pct > state.threshold) {
    state.alertFired = false;
    state.pendingAlertTime = null;
    hideAlertBanner();
    clearPendingTag();
    return;
  }

  if (state.alertFired) return;

  if (!isDayActive()) {
    showAlertBanner('deferred', 'Alerta inactivo hoje', 'Este dia não está activado.');
    return;
  }

  if (isInQuietHours()) {
    if (!state.pendingAlertTime) {
      state.pendingAlertTime = getQuietEndTime();
      showAlertBanner('deferred', 'Horário silencioso activo', `Alerta adiado para as ${state.pendingAlertTime}.`);
      showPendingTag(state.pendingAlertTime);
    }
  } else {
    state.alertFired = true;
    state.pendingAlertTime = null;
    clearPendingTag();
    playSound();
    showAlertBanner('alert', `⚡ Bateria em ${pct}%!`, 'Conecta o carregador agora.');

    // Notificação local via Capacitor (se disponível) ou Web Notifications
    sendNotification(`Bateria em ${pct}% — conecta o carregador!`);
  }
}

// ========================
// NOTIFICAÇÕES
// ========================
async function sendNotification(msg) {
  // Tenta Capacitor LocalNotifications primeiro
  try {
    const { LocalNotifications } = window.Capacitor?.Plugins || {};
    if (LocalNotifications) {
      await LocalNotifications.requestPermissions();
      await LocalNotifications.schedule({
        notifications: [{
          title: 'BatteryGuard ⚡',
          body: msg,
          id: 1,
          schedule: { at: new Date(Date.now() + 100) },
          sound: null,
          smallIcon: 'ic_stat_icon_config_sample',
          iconColor: '#00e5a0',
        }]
      });
      return;
    }
  } catch (e) {}

  // Fallback: Web Notifications API
  if ('Notification' in window) {
    if (Notification.permission === 'default') await Notification.requestPermission();
    if (Notification.permission === 'granted') {
      new Notification('BatteryGuard ⚡', { body: msg });
    }
  }
}

// ========================
// INIT BATERIA
// ========================
async function initBattery() {
  const { ok, mode } = await BatteryBridge.init((pct, charging) => {
    state.currentPct = pct;
    updateBatteryUI(pct, charging);
    if (state.active) checkBattery();
  });

  updateSourceBadge(mode);

  if (!ok) {
    document.getElementById('noSupport').style.display = 'block';
    updateBatteryUI(null, false);
  }
}

// ========================
// MONITOR TOGGLE
// ========================
function toggleMonitor() {
  state.active = !state.active;
  const btn = document.getElementById('mainBtn');
  const dot = document.getElementById('statusDot');

  if (state.active) {
    btn.textContent = '⏹ PARAR MONITORIZAÇÃO';
    btn.classList.remove('off');
    dot.classList.add('active');
    document.getElementById('statusText').textContent = 'activo';
    state.alertFired = false;
    state.pendingAlertTime = null;
    clearPendingTag();
    hideAlertBanner();
    checkBattery();
    state.checkInterval = setInterval(checkBattery, 30000);
    sendNotification('BatteryGuard activo — a monitorizar a bateria.');
  } else {
    btn.textContent = '▶ INICIAR MONITORIZAÇÃO';
    btn.classList.add('off');
    dot.classList.remove('active');
    document.getElementById('statusText').textContent = 'inactivo';
    clearInterval(state.checkInterval);
    hideAlertBanner();
    clearPendingTag();
  }
}

// ========================
// CONTROLOS UI
// ========================
function toggleQuiet() {
  state.quietEnabled = !state.quietEnabled;
  document.getElementById('quietToggle').classList.toggle('on', state.quietEnabled);
  document.getElementById('quietTimes').style.opacity = state.quietEnabled ? '1' : '0.4';
}

document.getElementById('thresholdSlider').addEventListener('input', function () {
  state.threshold = parseInt(this.value);
  document.getElementById('thresholdVal').textContent = this.value + '%';
  const marker = document.getElementById('thresholdMarker');
  marker.style.left = this.value + '%';
  marker.setAttribute('data-label', this.value + '%');
  state.alertFired = false;
  if (state.active) checkBattery();
});

document.getElementById('volumeSlider').addEventListener('input', function () {
  state.volume = this.value / 100;
  document.getElementById('volumeVal').textContent = this.value + '%';
});

document.getElementById('repeatSlider').addEventListener('input', function () {
  state.repeats = parseInt(this.value);
  document.getElementById('repeatVal').textContent = this.value + '×';
});

document.getElementById('quietStart').addEventListener('change', function () { state.quietStart = this.value; });
document.getElementById('quietEnd').addEventListener('change', function () {
  state.quietEnd = this.value;
  state.pendingAlertTime = null;
});

document.getElementById('daysGrid').addEventListener('click', function (e) {
  const btn = e.target.closest('.day-btn');
  if (!btn) return;
  const day = parseInt(btn.dataset.day);
  const idx = state.activeDays.indexOf(day);
  if (idx > -1) state.activeDays.splice(idx, 1); else state.activeDays.push(day);
  btn.classList.toggle('active', state.activeDays.includes(day));
});

document.getElementById('soundGrid').addEventListener('click', function (e) {
  const btn = e.target.closest('.sound-btn');
  if (!btn) return;
  document.querySelectorAll('.sound-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  state.selectedSound = btn.dataset.sound;
  state.customAudioUrl = null;
  document.getElementById('customFileName').textContent = 'Ficheiro personalizado';
  document.getElementById('customFileLabel').classList.remove('has-file');
});

function loadCustomSound(input) {
  const file = input.files[0];
  if (!file) return;
  state.customAudioUrl = URL.createObjectURL(file);
  document.getElementById('customFileName').textContent = file.name;
  document.getElementById('customFileLabel').classList.add('has-file');
  document.querySelectorAll('.sound-btn').forEach(b => b.classList.remove('active'));
}

function testSound() { playSound(); }

// ========================
// INIT
// ========================
initBattery();

// Verifica alertas pendentes a cada minuto
setInterval(() => {
  if (!state.active) return;
  if (state.pendingAlertTime && !isInQuietHours() && isDayActive()) {
    state.pendingAlertTime = null;
    clearPendingTag();
    state.alertFired = true;
    playSound();
    showAlertBanner('alert', '⚡ Bateria fraca!', 'Alerta pendente disparado.');
    sendNotification('Bateria fraca — conecta o carregador!');
  }
  checkBattery();
}, 60000);
</script>
