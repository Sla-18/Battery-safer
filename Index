<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#0a0a0f">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta http-equiv="Content-Security-Policy"
      content="default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://fonts.googleapis.com https://fonts.gstatic.com">
<title>BatteryGuard</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface2: #1a1a26;
    --border: #2a2a3f;
    --accent: #00e5a0;
    --accent2: #ff5f57;
    --accent3: #ffd60a;
    --text: #e8e8f0;
    --muted: #6b6b8a;
    --radius: 16px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
  }

  body::before {
    content: '';
    position: fixed;
    top: -30%;
    left: -20%;
    width: 70vw;
    height: 70vw;
    background: radial-gradient(circle, rgba(0,229,160,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    bottom: -20%;
    right: -20%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(255,95,87,0.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 480px;
    margin: 0 auto;
    padding: 20px 16px 100px;
    position: relative;
    z-index: 1;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0 24px;
  }

  .logo { font-size: 20px; font-weight: 800; letter-spacing: -0.5px; }
  .logo span { color: var(--accent); }

  .status-dot {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    background: var(--surface);
    padding: 6px 12px;
    border-radius: 50px;
    border: 1px solid var(--border);
  }

  .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--muted);
    transition: all 0.3s;
  }

  .dot.active {
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .battery-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 28px 24px;
    margin-bottom: 16px;
    position: relative;
    overflow: hidden;
  }

  .battery-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.5;
  }

  .battery-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .battery-main {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 20px;
  }

  .battery-pct {
    font-size: 72px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -4px;
    background: linear-gradient(135deg, var(--text), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    transition: all 0.5s;
  }

  .battery-icon-wrap {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
    padding-bottom: 8px;
  }

  .battery-status-text { font-family: 'DM Mono', monospace; font-size: 12px; color: var(--muted); }

  .charging-tag {
    background: rgba(0,229,160,0.15);
    color: var(--accent);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    border: 1px solid rgba(0,229,160,0.3);
    display: none;
  }

  .charging-tag.visible { display: block; }

  .batt-bar-container {
    position: relative;
    height: 10px;
    background: var(--surface2);
    border-radius: 50px;
    overflow: visible;
    margin-bottom: 8px;
  }

  .batt-bar-fill {
    height: 100%;
    border-radius: 50px;
    background: linear-gradient(90deg, var(--accent2), var(--accent3), var(--accent));
    transition: width 1s cubic-bezier(0.4,0,0.2,1);
    position: relative;
  }

  .batt-bar-glow {
    position: absolute;
    right: 0; top: 50%;
    transform: translateY(-50%);
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--accent);
    filter: blur(8px);
    opacity: 0.6;
  }

  .threshold-marker {
    position: absolute;
    top: -4px; bottom: -4px;
    width: 2px;
    background: var(--accent3);
    border-radius: 2px;
    transition: left 0.3s;
  }

  .threshold-marker::after {
    content: attr(data-label);
    position: absolute;
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--accent3);
    white-space: nowrap;
  }

  .batt-bar-labels {
    display: flex;
    justify-content: space-between;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
  }

  .alert-banner {
    background: rgba(255,95,87,0.12);
    border: 1px solid rgba(255,95,87,0.3);
    border-radius: 12px;
    padding: 12px 16px;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    display: none;
  }

  .alert-banner.show { display: flex; }
  .alert-banner.deferred { background: rgba(255,214,10,0.1); border-color: rgba(255,214,10,0.3); }
  .alert-banner-icon { font-size: 18px; }
  .alert-banner-text { font-size: 13px; line-height: 1.4; }
  .alert-banner-text strong { display: block; font-size: 12px; font-weight: 700; margin-bottom: 2px; }

  .section-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 12px;
  }

  .section-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .slider-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .slider-label { font-size: 13px; color: var(--muted); width: 110px; flex-shrink: 0; }

  .slider-value {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    width: 40px;
    text-align: right;
    flex-shrink: 0;
  }

  input[type=range] {
    -webkit-appearance: none;
    flex: 1;
    height: 4px;
    background: var(--surface2);
    border-radius: 50px;
    outline: none;
  }

  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    box-shadow: 0 0 10px rgba(0,229,160,0.4);
    transition: transform 0.15s;
  }

  input[type=range]:active::-webkit-slider-thumb { transform: scale(1.3); }

  .time-row { display: flex; align-items: center; gap: 10px; }
  .time-row .divider { color: var(--muted); font-family: 'DM Mono', monospace; font-size: 13px; }

  .time-group { display: flex; flex-direction: column; gap: 4px; flex: 1; }

  .time-group label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 1.5px;
    color: var(--muted);
    text-transform: uppercase;
  }

  input[type=time] {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    padding: 10px 12px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
  }

  input[type=time]:focus { border-color: var(--accent); }
  input[type=time]::-webkit-calendar-picker-indicator { filter: invert(0.5); }

  .toggle-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .toggle-row:last-child { margin-bottom: 0; }
  .toggle-info { display: flex; flex-direction: column; gap: 2px; }
  .toggle-name { font-size: 14px; font-weight: 600; }
  .toggle-desc { font-size: 11px; color: var(--muted); }

  .toggle {
    width: 48px; height: 26px;
    background: var(--surface2);
    border-radius: 50px;
    position: relative;
    cursor: pointer;
    transition: background 0.3s;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .toggle.on { background: var(--accent); border-color: var(--accent); }

  .toggle::after {
    content: '';
    position: absolute;
    top: 3px; left: 3px;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--bg);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }

  .toggle.on::after { transform: translateX(22px); background: #fff; }

  .days-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; }

  .day-btn {
    aspect-ratio: 1;
    border-radius: 8px;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
  }

  .day-btn.active {
    background: rgba(0,229,160,0.15);
    border-color: var(--accent);
    color: var(--accent);
    font-weight: 700;
  }

  .sound-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }

  .sound-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 10px 8px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .sound-btn.active { background: rgba(0,229,160,0.1); border-color: var(--accent); color: var(--accent); }
  .sound-btn .icon { font-size: 14px; }

  .custom-file-btn {
    grid-column: 1 / -1;
    background: var(--surface2);
    border: 1px dashed var(--border);
    border-radius: 10px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 12px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .custom-file-btn.has-file { border-color: var(--accent); color: var(--accent); background: rgba(0,229,160,0.05); }
  input[type=file] { display: none; }

  .test-btn {
    width: 100%;
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    padding: 12px;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 8px;
  }

  .test-btn:active { transform: scale(0.97); }

  .main-toggle-btn {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #000;
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 800;
    padding: 16px 40px;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    letter-spacing: 0.5px;
    box-shadow: 0 0 30px rgba(0,229,160,0.4);
    z-index: 100;
    white-space: nowrap;
  }

  .main-toggle-btn.off {
    background: var(--surface);
    color: var(--muted);
    border: 1px solid var(--border);
    box-shadow: none;
  }

  .main-toggle-btn:active { transform: translateX(-50%) scale(0.95); }

  .no-support {
    background: rgba(255,95,87,0.1);
    border: 1px solid rgba(255,95,87,0.3);
    border-radius: 12px;
    padding: 16px;
    font-size: 13px;
    line-height: 1.6;
    color: #ff9090;
    margin-bottom: 16px;
    display: none;
  }

  .pending-tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(255,214,10,0.1);
    border: 1px solid rgba(255,214,10,0.3);
    color: var(--accent3);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 4px 8px;
    border-radius: 6px;
    margin-top: 10px;
  }

  /* Badge de fonte de dados */
  .source-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 4px;
    margin-left: 8px;
    vertical-align: middle;
  }
  .source-badge.native {
    background: rgba(0,229,160,0.15);
    color: var(--accent);
    border: 1px solid rgba(0,229,160,0.3);
  }
  .source-badge.web {
    background: rgba(255,214,10,0.1);
    color: var(--accent3);
    border: 1px solid rgba(255,214,10,0.3);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .section-card, .battery-card { animation: slideUp 0.5s ease both; }
  .section-card:nth-child(1) { animation-delay: 0.05s; }
  .section-card:nth-child(2) { animation-delay: 0.1s; }
  .section-card:nth-child(3) { animation-delay: 0.15s; }
  .section-card:nth-child(4) { animation-delay: 0.2s; }

  @keyframes flash {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .alert-flash { animation: flash 0.5s ease 3; }
</style>
